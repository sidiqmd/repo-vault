CLIENT_URL=http://localhost:8081
PORT=5050

MONGODB_URI=mongodb://localhost:27017/repovault_dev
# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5050

# OAuth — get from GitHub Developer Settings / Google Cloud Console
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub PAT for API access (5000/hr). Without this, guests use web scraping.
GITHUB_PAT=

# Cache TTL in hours — how long before re-fetching repo data (default: 4320)
CACHE_TTL_HOURS=4320

# Anthropic API key for AI summary + auto-categorize (registered users only)
ANTHROPIC_API_KEY=

# Log level: fatal, error, warn, info, debug, trace
LOG_LEVEL=info
